{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bug Forge Gold Key",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "taskId", "candidateId", "status", "sourceRevision", "bugs", "noIssueRegions", "leakagePolicy", "approval"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "taskId": { "type": "string", "minLength": 1 },
    "candidateId": { "type": "string", "minLength": 1, "description": "Neutral ID visible to candidates." },
    "status": { "type": "string", "enum": ["draft", "locked", "retired"] },
    "sourceRevision": { "type": "string", "minLength": 1 },
    "fixturePatch": { "type": "string" },
    "referenceFixPatch": { "type": "string" },
    "bugs": { "type": "array", "items": { "$ref": "#/$defs/bug" } },
    "noIssueRegions": { "type": "array", "items": { "$ref": "#/$defs/region" } },
    "mustAvoidClaims": { "type": "array", "items": { "type": "string" } },
    "difficulty": { "$ref": "#/$defs/difficulty" },
    "leakagePolicy": { "$ref": "#/$defs/leakagePolicy" },
    "approval": { "$ref": "#/$defs/approval" }
  },
  "$defs": {
    "bug": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bugId", "severity", "category", "summary", "impact", "locations", "requiredEvidence", "acceptableFixes"],
      "properties": {
        "bugId": { "type": "string", "minLength": 1 },
        "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
        "category": { "type": "string", "enum": ["correctness", "safety", "security", "reliability", "performance", "api_contract", "test", "evaluation", "maintainability"] },
        "summary": { "type": "string", "minLength": 1 },
        "impact": { "type": "string", "minLength": 1 },
        "locations": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/region" } },
        "requiredEvidence": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/evidence" } },
        "acceptableFixes": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "mustNotSay": { "type": "array", "items": { "type": "string" } }
      }
    },
    "region": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file"],
      "properties": {
        "file": { "type": "string", "minLength": 1 },
        "startLine": { "type": "integer", "minimum": 1 },
        "endLine": { "type": "integer", "minimum": 1 },
        "symbol": { "type": "string" }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "quote", "matchMode"],
      "properties": {
        "file": { "type": "string", "minLength": 1 },
        "quote": { "type": "string", "minLength": 1 },
        "matchMode": { "type": "string", "enum": ["exact", "substring", "regex"] }
      }
    },
    "difficulty": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bucket", "plainExpected"],
      "properties": {
        "bucket": { "type": "string", "enum": ["easy", "medium", "hard", "no-issue", "adversarial", "uncalibrated"] },
        "plainExpected": { "type": "string", "enum": ["likely-catches", "mixed", "likely-misses", "unknown"] },
        "rationale": { "type": "string" }
      }
    },
    "leakagePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidateVisible", "candidateForbidden"],
      "properties": {
        "candidateVisible": { "type": "array", "items": { "type": "string" } },
        "candidateForbidden": { "type": "array", "items": { "type": "string" } }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "providerReviews", "approvedBy"],
      "properties": {
        "state": { "type": "string", "enum": ["draft", "needs-review", "approved", "rejected"] },
        "providerReviews": { "type": "array", "items": { "type": "string" } },
        "approvedBy": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" }
      }
    }
  }
}
