{
  "schemaVersion": 1,
  "name": "e2e-tree-failure-skip",
  "description": "Tree child is skipped when parent fails.",
  "defaults": {
    "backend": { "type": "local-pi", "mode": "tmux" },
    "maxConcurrency": 2,
    "tools": ["read", "grep", "find", "ls"]
  },
  "flow": {
    "type": "tree",
    "tasks": [
      {
        "id": "tree-root-fails",
        "cwd": "./e2e-test/fixtures/does-not-exist",
        "agent": "scout",
        "readOnly": true,
        "task": "This task should fail before child Pi starts because cwd is missing."
      },
      {
        "id": "tree-child-skipped",
        "parent": "tree-root-fails",
        "agent": "scout",
        "readOnly": true,
        "task": "This child should be skipped and must not launch."
      }
    ]
  }
}
