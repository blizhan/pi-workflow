{
  "name": "@agwab/pi-workflow",
  "version": "0.1.0",
  "description": "Workflow orchestration for Pi subagents.",
  "private": false,
  "type": "module",
  "license": "MIT",
  "files": [
    "src",
    "workflows",
    "skills",
    "docs/usage.md",
    "docs/ab-execution-results.md",
    "README.md",
    "LICENSE",
    "tsconfig.json"
  ],
  "keywords": [
    "pi-package",
    "pi-extension",
    "workflow",
    "pi"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./extension": "./src/extension.ts",
    "./package.json": "./package.json"
  },
  "bin": {
    "pi-workflow": "src/cli.mjs"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit",
    "test:unit": "rm -rf .tmp/unit && tsc -p tsconfig.json --outDir .tmp/unit --noEmit false && node --test test/*.test.mjs",
    "e2e": "node e2e-test/run.mjs",
    "e2e:soak": "node e2e-test/soak.mjs",
    "pack:dry": "npm pack --dry-run",
    "release:check": "node ./scripts/release-check.mjs"
  },
  "pi": {
    "extensions": [
      "./src/extension.ts"
    ],
    "skills": [
      "./skills/workflow-guide"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.78.0",
    "@earendil-works/pi-coding-agent": "*",
    "@types/node": "^24.0.0",
    "typebox": "^1.1.39",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "dependencies": {
    "@agwab/pi-subagent": "^0.3.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": false
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AgwaB/pi-workflow.git"
  },
  "homepage": "https://github.com/AgwaB/pi-workflow#readme",
  "bugs": {
    "url": "https://github.com/AgwaB/pi-workflow/issues"
  }
}
