{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "deep-research:research-questions",
  "type": "object",
  "required": [
    "schema",
    "digest",
    "question",
    "extractedFacts",
    "claims",
    "sources"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "minLength": 1
    },
    "digest": {
      "type": "string",
      "minLength": 1
    },
    "question": {},
    "extractedFacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      },
      "maxItems": 32
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      },
      "maxItems": 24
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      },
      "maxItems": 24
    }
  },
  "additionalProperties": true
}
