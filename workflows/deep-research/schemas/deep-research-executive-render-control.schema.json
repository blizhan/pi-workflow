{
  "type": "object",
  "required": [
    "schema",
    "digest",
    "status",
    "executiveMarkdown",
    "wordCount",
    "sourceUrlCount",
    "claimSummary",
    "factSlotSummary",
    "gates",
    "auditArtifact"
  ],
  "properties": {
    "schema": { "type": "string", "const": "deep-research-executive-render-v1" },
    "digest": { "type": "string" },
    "status": { "type": "string", "enum": ["passed", "failed", "blocked"] },
    "blockers": { "type": "array", "items": { "type": "string" } },
    "executiveMarkdown": { "type": "string" },
    "wordCount": { "type": "number" },
    "sourceUrlCount": { "type": "number" },
    "totalSourceUrlCount": { "type": "number" },
    "sourceUrls": { "type": "array", "items": { "type": "string" } },
    "claimSummary": {
      "type": "object",
      "required": ["total", "verified", "partially_supported", "unsupported", "conflicting"],
      "properties": {
        "total": { "type": "number" },
        "verified": { "type": "number" },
        "partially_supported": { "type": "number" },
        "unsupported": { "type": "number" },
        "conflicting": { "type": "number" }
      },
      "additionalProperties": true
    },
    "factSlotSummary": {
      "type": "object",
      "required": ["total", "filled", "partial", "missingOrConflicting"],
      "properties": {
        "total": { "type": "number" },
        "filled": { "type": "number" },
        "partial": { "type": "number" },
        "missingOrConflicting": { "type": "number" }
      },
      "additionalProperties": true
    },
    "gates": {
      "type": "object",
      "required": ["renderedAllStructuredItems", "passed"],
      "properties": {
        "renderedAllStructuredItems": { "type": "boolean" },
        "passed": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "auditArtifact": { "type": "string" },
    "sidecarPath": { "type": "string" },
    "reportSidecarPath": { "type": "string" },
    "auditSidecarPath": { "type": "string" },
    "reportMarkdown": { "type": "string" },
    "auditMarkdown": { "type": "string" },
    "renderMode": { "type": "string" },
    "sourceIndex": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "host": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "sectionCounts": {
      "type": "object",
      "additionalProperties": true
    },
    "renderWarnings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "section": { "type": "string" },
          "label": { "type": "string" },
          "total": { "type": "number" },
          "rendered": { "type": "number" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
