{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "impact-synthesis-control",
  "type": "object",
  "required": [
    "schema",
    "digest",
    "summary",
    "verdict",
    "riskLevel",
    "blockingIssues",
    "nonBlockingIssues",
    "confirmedSafeAreas",
    "recommendedNextActions",
    "validationToRun",
    "needsHuman"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "minLength": 1
    },
    "digest": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string"
    },
    "verdict": {
      "type": "string",
      "enum": [
        "READY",
        "NEEDS_WORK",
        "BLOCKED",
        "UNKNOWN"
      ]
    },
    "riskLevel": {
      "type": "string",
      "enum": [
        "none",
        "low",
        "medium",
        "high",
        "unknown"
      ]
    },
    "blockingIssues": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "nonBlockingIssues": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "confirmedSafeAreas": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "recommendedNextActions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "validationToRun": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "needsHuman": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": true
}
