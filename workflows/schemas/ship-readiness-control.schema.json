{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ship-readiness-control",
  "type": "object",
  "required": [
    "schema",
    "digest",
    "status",
    "requiredBeforeShip",
    "niceToHave",
    "assumptions"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "minLength": 1
    },
    "digest": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "ready",
        "needs-work",
        "blocked",
        "unknown"
      ]
    },
    "requiredBeforeShip": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "niceToHave": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": true
}
