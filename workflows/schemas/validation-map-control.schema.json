      "type": "string",
      "minLength": 1
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "docs": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "releaseArtifacts": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "validationCommandsMentioned": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "knownGaps": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": true
