{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "api-contract-impact-control",
  "type": "object",
  "required": [
    "schema",
    "digest",
    "status",
    "impacts",
    "assumptions"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "minLength": 1
    },
    "digest": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "none",
        "low",
        "medium",
        "high",
        "unknown"
      ]
    },
    "impacts": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": true
}
