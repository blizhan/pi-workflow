{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "validation-impact-control",
  "type": "object",
  "required": [
    "schema",
    "digest",
    "coverageStatus",
    "coveredAreas",
    "missingValidation",
    "recommendedCommands",
    "assumptions"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "minLength": 1
    },
    "digest": {
      "type": "string",
      "minLength": 1
    },
    "coverageStatus": {
      "type": "string",
      "enum": [
        "none",
        "partial",
        "strong",
        "unknown"
      ]
    },
    "coveredAreas": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "missingValidation": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "recommendedCommands": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": true
}
