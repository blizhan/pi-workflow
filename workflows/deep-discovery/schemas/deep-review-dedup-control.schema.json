{
  "type": "object",
  "required": [
    "schema",
    "digest",
    "findings",
    "sourceStatusSummary",
    "dedupSummary"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "minLength": 1
    },
    "digest": {
      "type": "string",
      "minLength": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "findingId",
          "rootCauseId",
          "title",
          "severity",
          "locations",
          "evidenceQuotes"
        ],
        "properties": {
          "findingId": {
            "type": "string",
            "minLength": 1
          },
          "rootCauseId": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "minLength": 1
          },
          "file": {
            "type": "string",
            "minLength": 1
          },
          "locations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "file"
              ],
              "properties": {
                "file": {
                  "type": "string",
                  "minLength": 1
                },
                "line": {
                  "type": "number"
                },
                "lineEnd": {
                  "type": "number"
                },
                "symbol": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "evidenceQuotes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "sourceStatusSummary": {
      "type": "object",
      "required": [
        "total",
        "completed",
        "nonCompleted",
        "partialFailures"
      ],
      "properties": {
        "total": {
          "type": "number",
          "minimum": 0
        },
        "completed": {
          "type": "number",
          "minimum": 0
        },
        "nonCompleted": {
          "type": "number",
          "minimum": 0
        },
        "partialFailures": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "status"
            ],
            "properties": {
              "source": {
                "type": "string"
              },
              "displayName": {
                "type": "string"
              },
              "taskId": {
                "type": "string"
              },
              "specId": {
                "type": "string"
              },
              "stageId": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "minLength": 1
              },
              "statusDetail": {
                "type": "string"
              },
              "lastMessage": {
                "type": "string"
              },
              "errorType": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "dedupSummary": {
      "type": "object",
      "required": [
        "rawCount",
        "uniqueCount",
        "duplicateCount",
        "duplicates"
      ],
      "properties": {
        "rawCount": {
          "type": "number",
          "minimum": 0
        },
        "uniqueCount": {
          "type": "number",
          "minimum": 0
        },
        "duplicateCount": {
          "type": "number",
          "minimum": 0
        },
        "duplicates": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    }
  }
}
