{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "contract-consistency-control",
  "type": "object",
  "required": [
    "schema",
    "digest",
    "status",
    "issues",
    "confirmedConsistencies"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "minLength": 1
    },
    "digest": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "warn",
        "fail",
        "unknown"
      ]
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "confirmedConsistencies": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": true
}
