{
  "type": "object",
  "required": [
    "schema",
    "digest",
    "summary",
    "verdict",
    "findings",
    "risks",
    "needsHuman",
    "evidenceIndex",
    "recommendedNextAction"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "minLength": 1
    },
    "digest": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": [
        "string",
        "object"
      ]
    },
    "verdict": {
      "type": "string",
      "minLength": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "findingId",
          "rootCauseId",
          "title",
          "severity",
          "locations",
          "evidenceQuotes"
        ],
        "properties": {
          "findingId": {
            "type": "string",
            "minLength": 1
          },
          "rootCauseId": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "minLength": 1
          },
          "file": {
            "type": "string",
            "minLength": 1
          },
          "locations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "file"
              ],
              "properties": {
                "file": {
                  "type": "string",
                  "minLength": 1
                },
                "line": {
                  "type": "number"
                },
                "lineEnd": {
                  "type": "number"
                },
                "symbol": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "evidenceQuote": {
            "type": "string"
          },
          "evidenceQuotes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "counterEvidence": {
            "type": "array"
          },
          "recommendedAction": {
            "type": "string"
          },
          "mergedFindingIds": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "risks": {
      "type": [
        "array",
        "object"
      ],
      "items": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "object"
          }
        ]
      }
    },
    "needsHuman": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "title"
        ],
        "properties": {
          "findingId": {
            "type": "string"
          },
          "rootCauseId": {
            "type": "string"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string"
          },
          "locations": {
            "type": "array"
          },
          "evidenceQuotes": {
            "type": "array"
          }
        }
      }
    },
    "evidenceIndex": {
      "type": [
        "array",
        "object"
      ]
    },
    "recommendedNextAction": {
      "type": "string",
      "minLength": 1
    }
  }
}
