{
  "type": "object",
  "required": [
    "schema",
    "digest",
    "findings"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "minLength": 1
    },
    "digest": {
      "type": "string",
      "minLength": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "severity",
          "title",
          "file"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "file": {
            "type": "string",
            "minLength": 1
          },
          "locations": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "file"
              ],
              "properties": {
                "file": {
                  "type": "string",
                  "minLength": 1
                },
                "line": {
                  "type": "number"
                },
                "lineEnd": {
                  "type": "number"
                },
                "symbol": {
                  "type": "string"
                }
              }
            }
          },
          "evidenceQuote": {
            "type": "string"
          },
          "evidenceQuotes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
