{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "spec-review:analysis.candidate-findings",
  "type": "object",
  "required": [
    "schema",
    "digest",
    "candidateFindings",
    "requirementCoverage"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "minLength": 1
    },
    "digest": {
      "type": "string",
      "minLength": 1
    },
    "candidateFindings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      },
      "maxItems": 30
    },
    "requirementCoverage": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      },
      "maxItems": 40
    }
  },
  "additionalProperties": true
}
