{
  "type": "object",
  "required": [
    "schema",
    "digest",
    "riskLevel",
    "risks",
    "riskReducers"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "minLength": 1
    },
    "digest": {
      "type": "string",
      "minLength": 1
    },
    "riskLevel": {
      "type": "string",
      "enum": [
        "none",
        "low",
        "medium",
        "high",
        "unknown"
      ]
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "riskReducers": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}
