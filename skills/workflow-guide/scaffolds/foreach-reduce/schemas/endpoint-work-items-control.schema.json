{
  "type": "object",
  "required": [
    "schema",
    "digest",
    "endpoints"
  ],
  "properties": {
    "schema": { "type": "string", "minLength": 1 },
    "digest": { "type": "string", "minLength": 1 },
    "endpoints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "method", "path", "docClaims", "suspectedGaps"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "method": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "title": { "type": "string" },
          "docClaims": { "type": "array", "items": { "type": "object" }, "maxItems": 20 },
          "implementationSignals": { "type": "array", "items": { "type": "object" }, "maxItems": 20 },
          "testSignals": { "type": "array", "items": { "type": "object" }, "maxItems": 20 },
          "suspectedGaps": { "type": "array", "items": { "type": "object" }, "maxItems": 20 },
          "uncertainty": { "type": "string" },
          "priority": { "type": "string", "enum": ["high", "medium", "low"] }
        }
      },
      "maxItems": 80
    },
    "crossCuttingClaims": { "type": "array", "items": { "type": "object" }, "maxItems": 40 },
    "needsHuman": { "type": "array", "items": { "type": "object" }, "maxItems": 40 },
    "noIssueNotes": { "type": "array", "items": { "type": "object" }, "maxItems": 40 }
  }
}
