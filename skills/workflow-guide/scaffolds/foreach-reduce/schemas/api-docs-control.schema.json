{
  "type": "object",
  "required": [
    "schema",
    "digest",
    "apiDocSources",
    "documentedEndpoints"
  ],
  "properties": {
    "schema": { "type": "string", "minLength": 1 },
    "digest": { "type": "string", "minLength": 1 },
    "apiDocSources": {
      "type": "array",
      "items": { "type": "object" },
      "maxItems": 40
    },
    "documentedEndpoints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "method", "path", "docEvidence"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "method": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "title": { "type": "string" },
          "docEvidence": { "type": "array", "items": { "type": "object" }, "maxItems": 12 },
          "requestContract": { "type": "object" },
          "responseContract": { "type": "object" },
          "authContract": { "type": "object" },
          "errorContract": { "type": "object" },
          "testSignals": { "type": "array", "items": { "type": "string" }, "maxItems": 12 }
        }
      },
      "maxItems": 80
    },
    "globalRules": { "type": "array", "items": { "type": "object" }, "maxItems": 30 },
    "ambiguities": { "type": "array", "items": { "type": "object" }, "maxItems": 30 },
    "outOfScope": { "type": "array", "items": { "type": "string" }, "maxItems": 30 }
  }
}
