{
  "type": "object",
  "required": [
    "schema",
    "digest",
    "implementationEndpoints",
    "testCoverage"
  ],
  "properties": {
    "schema": { "type": "string", "minLength": 1 },
    "digest": { "type": "string", "minLength": 1 },
    "implementationEndpoints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["method", "path", "files", "observedBehavior"],
        "properties": {
          "method": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "files": { "type": "array", "items": { "type": "string" }, "maxItems": 20 },
          "observedBehavior": { "type": "string" },
          "implementationEvidence": { "type": "array", "items": { "type": "object" }, "maxItems": 20 },
          "validationSignals": { "type": "array", "items": { "type": "string" }, "maxItems": 20 },
          "authSignals": { "type": "array", "items": { "type": "string" }, "maxItems": 20 },
          "errorSignals": { "type": "array", "items": { "type": "string" }, "maxItems": 20 },
          "relatedTests": { "type": "array", "items": { "type": "string" }, "maxItems": 20 }
        }
      },
      "maxItems": 100
    },
    "testCoverage": {
      "type": "array",
      "items": { "type": "object" },
      "maxItems": 100
    },
    "unmappedAreas": { "type": "array", "items": { "type": "object" }, "maxItems": 40 },
    "notes": { "type": "array", "items": { "type": "string" }, "maxItems": 40 }
  }
}
