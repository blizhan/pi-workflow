{
  "type": "object",
  "required": [
    "schema",
    "digest",
    "verdict",
    "summary",
    "requiredArtifactUsed",
    "followUps"
  ],
  "properties": {
    "schema": { "type": "string", "minLength": 1 },
    "digest": { "type": "string", "minLength": 1 },
    "verdict": {
      "type": "string",
      "enum": ["pass", "needs_attention", "inconclusive"]
    },
    "summary": { "type": "string" },
    "requiredArtifactUsed": { "type": "boolean" },
    "followUps": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
