{
  "schemaVersion": 1,
  "name": "rank-example",
  "description": "Explicit rank join task that orders alternatives with evidence and caveats.",
  "defaults": {
    "backend": { "type": "local-pi", "mode": "tmux" },
    "tools": ["read", "grep", "find", "ls"]
  },
  "flow": {
    "type": "parallel",
    "tasks": [
      { "id": "candidate-a", "agent": "scout", "readOnly": true, "task": "Assess candidate A." },
      { "id": "candidate-b", "agent": "scout", "readOnly": true, "task": "Assess candidate B." }
    ],
    "rank": {
      "id": "ranking",
      "agent": "scout",
      "readOnly": true,
      "task": "Use the Rank Context to rank candidates with explicit criteria, evidence, and uncertainty."
    }
  }
}
