{
  "schemaVersion": 1,
  "name": "budget-guard-example",
  "description": "Static provider-aware budget estimate with explicit local model rates. Rates are supplied by the spec, not fetched from providers.",
  "defaults": {
    "backend": { "type": "local-pi", "mode": "tmux" },
    "model": "openai-codex/gpt-5.5",
    "tools": ["read", "grep", "find", "ls"]
  },
  "budget": {
    "maxEstimatedTokens": 50000,
    "maxEstimatedUsd": 1,
    "expectedOutputTokensPerTask": 1000,
    "onExceed": "warn",
    "modelRates": {
      "openai-codex/*": {
        "inputUsdPerMillionTokens": 1,
        "outputUsdPerMillionTokens": 2
      }
    }
  },
  "flow": {
    "type": "single",
    "task": {
      "id": "estimate-demo",
      "agent": "scout",
      "readOnly": true,
      "task": "Inspect the repository and summarize the main package surfaces."
    }
  }
}
