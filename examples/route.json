{
  "schemaVersion": 1,
  "name": "route-example",
  "description": "Deterministically route static items to specialist task templates.",
  "defaults": {
    "backend": { "type": "local-pi", "mode": "tmux" },
    "tools": ["read", "grep", "find", "ls"]
  },
  "flow": {
    "type": "route",
    "items": [
      { "id": "frontend-file", "route": "frontend", "input": "src/ui.tsx" },
      { "id": "backend-file", "route": "backend", "input": "src/api.ts" }
    ],
    "routes": [
      {
        "id": "frontend",
        "task": {
          "id": "frontend-review",
          "agent": "scout",
          "readOnly": true,
          "task": "Review the frontend item named in the Route Item Context."
        }
      },
      {
        "id": "backend",
        "task": {
          "id": "backend-review",
          "agent": "scout",
          "readOnly": true,
          "task": "Review the backend item named in the Route Item Context."
        }
      }
    ],
    "aggregate": {
      "id": "route-summary",
      "agent": "scout",
      "readOnly": true,
      "task": "Summarize the routed outputs."
    }
  }
}
